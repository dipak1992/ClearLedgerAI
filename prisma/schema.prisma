generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  ADMIN
  EDITOR
  VIEWER
}

enum TransactionType {
  EXPENSE
  INCOME
  TRANSFER
  REIMBURSEMENT
}

enum DebtType {
  LENT
  BORROWED
  CUSTOMER_UNPAID
  ADVANCE_PAYMENT
  REIMBURSEMENT_PENDING
}

enum DebtStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
}

enum AttachmentKind {
  RECEIPT
  SCREENSHOT
  PDF
  PROOF
  OTHER
}

enum SubscriptionPlan {
  FREE
  PRO
  FAMILY
  BUSINESS
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum NotificationType {
  INVITE
  REMINDER
  ALERT
  SETTLEMENT
  COMMENT
}

enum MoneyRecordType {
  EXPENSE
  INCOME
  DEBT_GIVEN
  DEBT_BORROWED
  SPLIT_EXPENSE
  TRANSFER
  REIMBURSEMENT
}

enum MoneyRecordStatus {
  PENDING
  CLEARED
  PAID
  PARTIAL
  OVERDUE
  VOID
}

model User {
  id                String              @id @default(cuid())
  authUserId        String?             @unique
  name              String?
  emailVerified     DateTime?
  image             String?
  email             String              @unique
  fullName          String?
  avatarUrl         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  workspaces        Workspace[]         @relation("WorkspaceOwner")
  memberships       WorkspaceMember[]
  transactions      Transaction[]
  debts             Debt[]              @relation("DebtCreator")
  debtPayments      DebtPayment[]
  debtNotes         DebtNote[]
  comments          Comment[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  subscriptions     Subscription[]
  accounts          Account[]
  sessions          Session[]
  moneyRecords      MoneyRecord[]       @relation("MoneyRecordCreator")
  moneyRecordPayments MoneyRecordPayment[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id                String              @id @default(cuid())
  ownerId           String
  name              String
  slug              String              @unique
  description       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  owner             User                @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members           WorkspaceMember[]
  transactions      Transaction[]
  debts             Debt[]
  categories        Category[]
  comments          Comment[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  subscriptions     Subscription[]
  moneyRecords      MoneyRecord[]
}

model WorkspaceMember {
  id                String              @id @default(cuid())
  workspaceId       String
  userId            String
  role              WorkspaceRole       @default(EDITOR)
  invitedEmail      String?
  joinedAt          DateTime?
  createdAt         DateTime            @default(now())
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Category {
  id                String              @id @default(cuid())
  workspaceId       String
  name              String
  color             String?
  icon              String?
  createdAt         DateTime            @default(now())
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  moneyRecords      MoneyRecord[]

  @@unique([workspaceId, name])
}

model Transaction {
  id                String              @id @default(cuid())
  workspaceId       String
  createdById       String
  categoryId        String?
  title             String
  amount            Decimal             @db.Decimal(12, 2)
  currency          String              @default("USD")
  transactionType   TransactionType     @default(EXPENSE)
  merchant          String?
  transactionDate   DateTime
  paymentMethod     String?
  accountMask       String?
  notes             String?
  aiSource          String?
  splitConfig       Json?
  metadata          Json?
  moneyRecordId     String?             @unique
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy         User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  category          Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  moneyRecord       MoneyRecord?        @relation("TransactionMoneyRecord", fields: [moneyRecordId], references: [id], onDelete: SetNull)
  attachments       TransactionAttachment[]
  comments          Comment[]
}

model TransactionAttachment {
  id                String              @id @default(cuid())
  transactionId     String
  kind              AttachmentKind      @default(RECEIPT)
  fileName          String
  storagePath       String
  mimeType          String?
  sizeBytes         Int?
  createdAt         DateTime            @default(now())
  transaction       Transaction         @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Debt {
  id                String              @id @default(cuid())
  workspaceId       String
  createdById       String
  counterpartyName  String
  amountTotal       Decimal             @db.Decimal(12, 2)
  amountPaid        Decimal             @default(0) @db.Decimal(12, 2)
  balanceRemaining  Decimal             @db.Decimal(12, 2)
  currency          String              @default("USD")
  type              DebtType
  status            DebtStatus          @default(OPEN)
  purpose           String?
  dateCreated       DateTime            @default(now())
  dueDate           DateTime?
  method            String?
  notes             String?
  metadata          Json?
  moneyRecordId     String?             @unique
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy         User                @relation("DebtCreator", fields: [createdById], references: [id], onDelete: Cascade)
  moneyRecord       MoneyRecord?        @relation("DebtMoneyRecord", fields: [moneyRecordId], references: [id], onDelete: SetNull)
  payments          DebtPayment[]
  timelineNotes     DebtNote[]
  attachments       DebtAttachment[]
  comments          Comment[]
}

model DebtPayment {
  id                String              @id @default(cuid())
  debtId            String
  createdById       String
  amount            Decimal             @db.Decimal(12, 2)
  paymentDate       DateTime            @default(now())
  method            String?
  notes             String?
  createdAt         DateTime            @default(now())
  debt              Debt                @relation(fields: [debtId], references: [id], onDelete: Cascade)
  createdBy         User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model DebtNote {
  id                String              @id @default(cuid())
  debtId            String
  createdById       String
  body              String
  createdAt         DateTime            @default(now())
  debt              Debt                @relation(fields: [debtId], references: [id], onDelete: Cascade)
  createdBy         User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model DebtAttachment {
  id                String              @id @default(cuid())
  debtId            String
  kind              AttachmentKind      @default(PROOF)
  fileName          String
  storagePath       String
  mimeType          String?
  sizeBytes         Int?
  createdAt         DateTime            @default(now())
  debt              Debt                @relation(fields: [debtId], references: [id], onDelete: Cascade)
}

model Comment {
  id                String              @id @default(cuid())
  workspaceId       String
  authorId          String
  transactionId     String?
  debtId            String?
  body              String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author            User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  transaction       Transaction?        @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  debt              Debt?               @relation(fields: [debtId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                String              @id @default(cuid())
  workspaceId       String
  userId            String
  stripeCustomerId  String?             @unique
  stripePriceId     String?
  stripeSubId       String?             @unique
  plan              SubscriptionPlan    @default(FREE)
  status            SubscriptionStatus  @default(TRIALING)
  currentPeriodEnd  DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id                String              @id @default(cuid())
  workspaceId       String
  actorId           String
  action            String
  entityType        String
  entityId          String
  payload           Json?
  createdAt         DateTime            @default(now())
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor             User                @relation(fields: [actorId], references: [id], onDelete: Cascade)
}

model Notification {
  id                String              @id @default(cuid())
  workspaceId       String
  userId            String
  type              NotificationType
  title             String
  body              String?
  readAt            DateTime?
  createdAt         DateTime            @default(now())
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}
// ==============================================================
// Unified Money Records engine (Phase 1).
//
// Every entry in the product is a MoneyRecord. Legacy Transaction
// and Debt tables continue to exist and are dual-written during
// the migration period. Once Phase 9 completes they can be retired.
// ==============================================================
model MoneyRecord {
  id                  String                 @id @default(cuid())
  workspaceId         String
  createdById         String
  categoryId          String?
  type                MoneyRecordType
  status              MoneyRecordStatus      @default(PENDING)
  title               String?
  amount              Decimal                @db.Decimal(12, 2)
  amountPaid          Decimal                @default(0) @db.Decimal(12, 2)
  currency            String                 @default("USD")
  occurredAt          DateTime
  dueDate             DateTime?
  counterpartyName    String?
  counterpartyUserId  String?
  merchant            String?
  paymentMethod       String?
  notes               String?
  aiSource            String?
  metadata            Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  workspace           Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy           User                   @relation("MoneyRecordCreator", fields: [createdById], references: [id], onDelete: Cascade)
  category            Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  attachments         MoneyRecordAttachment[]
  splits              MoneyRecordSplit[]
  payments            MoneyRecordPayment[]
  transaction         Transaction?           @relation("TransactionMoneyRecord")
  debt                Debt?                  @relation("DebtMoneyRecord")

  @@index([workspaceId, occurredAt])
  @@index([workspaceId, type])
  @@index([workspaceId, status])
}

model MoneyRecordAttachment {
  id              String          @id @default(cuid())
  recordId        String
  kind            AttachmentKind  @default(RECEIPT)
  fileName        String
  storagePath     String
  mimeType        String?
  sizeBytes       Int?
  createdAt       DateTime        @default(now())
  record          MoneyRecord     @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
}

model MoneyRecordSplit {
  id                  String          @id @default(cuid())
  recordId            String
  participantEmail    String?
  participantUserId   String?
  share               Decimal         @db.Decimal(12, 2)
  settledAt           DateTime?
  createdAt           DateTime        @default(now())
  record              MoneyRecord     @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
}

model MoneyRecordPayment {
  id              String          @id @default(cuid())
  recordId        String
  createdById     String
  amount          Decimal         @db.Decimal(12, 2)
  paymentDate     DateTime        @default(now())
  method          String?
  notes           String?
  createdAt       DateTime        @default(now())
  record          MoneyRecord     @relation(fields: [recordId], references: [id], onDelete: Cascade)
  createdBy       User            @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([recordId])
}
